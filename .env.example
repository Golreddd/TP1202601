# Copia este archivo a .env y completa los valores
# En producción (Render) configura estas variables en el dashboard

# ── Seguridad ──────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-CAMBIA-ESTO
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos (desarrollo local — en producción usar DATABASE_URL) ─────
DB_NAME=sigamos_db
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_AQUI
DB_HOST=localhost
DB_PORT=5432

# ── Base de datos (producción Render — reemplaza las vars individuales) ────
# DATABASE_URL=postgres://user:password@host:port/dbname

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SIGNING_KEY=SEBASTIANRODRIGO
JWT_ACCESS_HOURS=1
JWT_REFRESH_DAYS=7

# ── Correo ─────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@sigamos.pe
